# ---- Core ----
# Single-user bearer token guarding the API. Change this before any real use.
API_TOKEN=dev-local-token-change-me

# Postgres (matches docker-compose service name "db")
DATABASE_URL=postgresql+asyncpg://lifeos:lifeos@db:5432/lifeos

# When true, no external network calls are made (embeddings use the deterministic
# mock provider, weather/calendar/email are stubbed in later phases). Phase 1 runs
# fully in this mode with no paid keys.
MOCK_INTEGRATIONS=true

TIMEZONE=America/New_York

# ---- LLM (Phase 2+; unused in Phase 1) ----
ANTHROPIC_API_KEY=
MODEL_MAIN=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001

# ---- Embeddings ----
# Provider behind the EmbeddingProvider interface. If EMBEDDING_API_KEY is set and
# MOCK_INTEGRATIONS=false, the Voyage provider (voyage-3, 1024-dim) is used.
# Otherwise a deterministic 1024-dim mock is used so search still works offline.
EMBEDDING_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# ---- Integrations (Phase 2+; unused in Phase 1) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
RESEND_API_KEY=
BRIEFING_EMAIL_TO=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BRIEFING_HOUR=06
WEEKLY_PLAN_DAY=SUN
WEEKLY_PLAN_HOUR=16

# ---- Location (Phase 2 weather) ----
LATITUDE=40.7128
LONGITUDE=-74.0060
